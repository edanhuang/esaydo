{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EasyDo",
  "version": "0.1.0",
  "identifier": "com.edanhuang.easydo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1180,
        "height": 760,
        "minWidth": 840,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/easydo-cli"
    ],
    "resources": {
      "../skills/": "skills/"
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
