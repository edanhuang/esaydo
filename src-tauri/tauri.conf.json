{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EasyDo",
  "version": "0.1.0",
  "identifier": "com.edanhuang.easydo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EasyDo",
        "width": 1180,
        "height": 760,
        "minWidth": 840,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
